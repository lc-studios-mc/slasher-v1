{
	"format_version": "1.10.0",
	"particle_effect": {
		"description": {
			"identifier": "slasher:slasher_trail_emitter",
			"basic_render_parameters": {
				"material": "particles_alpha",
				"texture": "textures/slasher/square"
			}
		},
		"curves": {
			"variable.offset_curve": {
				"type": "bezier_chain",
				"input": "v.emitter_age / v.emitter_lifetime",
				"nodes": {
					"0.0": {
						"value": 0,
						"slope": 2.05
					},
					"1.0": {
						"value": 1,
						"slope": 0.1
					}
				}
			}
		},
		"components": {
			"minecraft:emitter_initialization": {
				"creation_expression": "v.dir_x = 0;v.dir_y = 0;v.dir_z = 0;",
				"per_update_expression": "v.offset_move = v.offset_curve;"
			},
			"minecraft:emitter_rate_steady": {
				"spawn_rate": 100,
				"max_particles": 100
			},
			"minecraft:emitter_lifetime_once": {
				"active_time": 0.2
			},
			"minecraft:emitter_shape_point": {
				"offset": ["v.dir_x * v.offset_move", "v.dir_y * v.offset_move", "v.dir_z * v.offset_move"]
			},
			"minecraft:particle_lifetime_expression": {
				"max_lifetime": 0.2
			},
			"minecraft:particle_initial_spin": {
				"rotation": "math.random(-180,180)",
				"rotation_rate": 100
			},
			"minecraft:particle_initial_speed": 0.5,
			"minecraft:particle_motion_dynamic": {},
			"minecraft:particle_appearance_billboard": {
				"size": [0.05, 0.05],
				"facing_camera_mode": "rotate_xyz",
				"uv": {
					"texture_width": 2,
					"texture_height": 2,
					"uv": [0, 0],
					"uv_size": [2, 2]
				}
			}
		}
	}
}
